document.addEventListener('click', function(e) {
  const btn = e.target.closest('.m-info-cart-btn');
  if (!btn) return;

  e.preventDefault();

  const variantId = btn.dataset.variantId;

  fetch('/cart/add.js', {
    method: 'POST',
    headers: {
      'Content-Type': 'application/json'
    },
    body: JSON.stringify({
      id: variantId,
      quantity: 1
    })
  })
  .then(res => res.json())
  .then(() => {
    // Pass open: true — onCartRefresh will refresh cart AND then call cartElement.open()
    document.dispatchEvent(new CustomEvent('cart:refresh', { detail: { open: true } }));
  })
  .catch(err => console.error(err));
});

