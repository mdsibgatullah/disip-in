{% stylesheet %}
  /* ===== Product Card Image Slider ===== */
.m-product-card__slider {
  position: relative;
  overflow: hidden;
  border-radius: inherit;
}

.m-product-card__slider::before {
  content: '';
  display: block;
  padding-top: calc(100% / (var(--aspect-ratio, 1)));
}

.m-product-card__slider-track {
  position: absolute;
  inset: 0;
  display: flex;
  transition: transform 0.38s cubic-bezier(0.4, 0, 0.2, 1);
  will-change: transform;
}

.m-product-card__slide {
  flex: 0 0 100%;
  width: 100%;
  position: relative;
}

.m-product-card__slide .m-image {
  position: absolute;
  inset: 0;
}

.m-product-card__slide img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

/* Arrows */
.m-pcard-arrow {
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  z-index: 10;
  background: #ffffff30;
  -webkit-backdrop-filter: blur(8px);
  backdrop-filter: blur(8px);
  border: none;
  border-radius: 50%;
  width: 50px;
  height: 50px;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  box-shadow: 0 2px 8px rgba(0,0,0,0.15);
  opacity: 0;
  transition: opacity 0.22s ease, background 0.18s ease, transform 0.18s ease;
  color: #222;
}
.l-arrow, .r-arrow{
   height: 22px;
   width: 22px;
}

.m-pcard-arrow--prev { left: 10px; }
.m-pcard-arrow--next { right: 10px; }

.m-product-card__media:hover .m-pcard-arrow,
.m-product-card__slider:hover .m-pcard-arrow {
  opacity: .6;
}

.m-pcard-arrow:hover {
  background: #fff;
  box-shadow: 0 4px 14px rgba(0,0,0,0.22);
}

.m-pcard-arrow--prev:hover { transform: translateY(-50%) scale(1.08); }
.m-pcard-arrow--next:hover { transform: translateY(-50%) scale(1.08); }

.m-pcard-arrow:active { transform: translateY(-50%) scale(0.94); }

/* Hide arrows if single image */
.m-product-card__slider[data-total="1"] .m-pcard-arrow { display: none; }

/* Dots */
.m-pcard-dots {
  position: absolute;
  bottom: 8px;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  gap: 5px;
  z-index: 10;
  pointer-events: none;
}

.m-pcard-dot {
  width: 5px;
  height: 5px;
  border-radius: 50%;
  background: rgba(255,255,255,0.55);
  transition: background 0.2s ease, transform 0.2s ease;
}

.m-pcard-dot.is-active {
  background: #fff;
  transform: scale(1.3);
}

/* Mobile: always show arrows slightly */
@media (max-width: 749px) {
  .m-pcard-arrow {
    opacity: 0.7;
    width: 30px;
    height: 30px;
  }
 .l-arrow, .r-arrow{
   height: 18px;
   width: 18px;
}

}



