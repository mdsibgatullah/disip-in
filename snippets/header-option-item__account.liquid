{% if shop.customer_accounts_enabled or shop.customer_accounts_optional %}
  {% if display_by == 'icon' %}
    <a
      href="{{ routes.account_url }}"
      class="m-header__account{% if box_size != blank %} {{ box_size }}{% endif %}"
      aria-label="{{ 'layout.customer.account' | t  }}"
    >
      <span class="m-tooltip m:block m-tooltip--bottom m-tooltip--style-2">
        {% comment %} <svg
          class="m-svg-icon--medium"
          fill="currentColor"
          stroke="currentColor"
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 448 512"
        >
          <path d="M313.6 304c-28.7 0-42.5 16-89.6 16-47.1 0-60.8-16-89.6-16C60.2 304 0 364.2 0 438.4V464c0 26.5 21.5 48 48 48h352c26.5 0 48-21.5 48-48v-25.6c0-74.2-60.2-134.4-134.4-134.4zM400 464H48v-25.6c0-47.6 38.8-86.4 86.4-86.4 14.6 0 38.3 16 89.6 16 51.7 0 74.9-16 89.6-16 47.6 0 86.4 38.8 86.4 86.4V464zM224 288c79.5 0 144-64.5 144-144S303.5 0 224 0 80 64.5 80 144s64.5 144 144 144zm0-240c52.9 0 96 43.1 96 96s-43.1 96-96 96-96-43.1-96-96 43.1-96 96-96z"/>
        </svg> {% endcomment %}


        <svg
  class="m-svg-icon--medium sv-user-icon"
  id="sv-user-icon"
  fill="currentColor"
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 512 512"
>
  <path d="M256 0c-68.4 0-123.8 55.4-123.8 123.8S187.6 247.6 256 247.6s123.8-55.4 123.8-123.8S324.4 0 256 0zm0 292.1c-33 0-63.5-9.3-87.9-25.1-18.9-12.1-43.5-10.1-60.1 5-46.1 41.7-72.3 101.1-72.2 163.4v26.7c0 27.6 22.4 49.9 50 49.9h340.4c27.6 0 50-22.3 50-49.9v-26.7c.1-62.3-26.1-121.6-72.2-163.4-16.6-15.1-41.2-17.1-60.1-5-24.4 15.8-54.9 25.1-87.9 25.1z"/>
</svg>
        <span class="m-tooltip__content">{{ 'layout.customer.account' | t }}</span>
      </span>
    </a>
  {% else %}
    <a
      href="{{ routes.account_url }}"
      class="m-header__account-text{% if box_size != blank %} {{ box_size }}{% endif %}"
      aria-label="{{ 'layout.customer.account' | t  }}"
    >
      {{ 'layout.customer.account' | t }}
    </a>
  {% endif %}
{% endif %}
