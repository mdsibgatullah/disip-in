.template-index #sv_header_logo, 
.template-index #msv_header_logo {
    animation: grow-progresss forwards;
    animation-timeline: scroll(root);
    animation-range: 0px 500px;
}

@keyframes grow-progresss {
    0% {
        transform: scale(2.8) translateY(-90px);
    }
    100% {
        transform: scale(1) translateY(0px);
    }
}

@media screen and (max-width: 768px){
    @keyframes grow-progresss {
        from {
            transform: scale(3) translateY(-80px);
        }
        to {
            transform: scale(1) translateY(0px);
        }
    }
}



