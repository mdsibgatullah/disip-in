.m-scroll-trigger.animate--fade-in-up {
  opacity: 0;
  transform: translateY(80px);
  transition: opacity 2s cubic-bezier(0.25, 0.46, 0.45, 0.94),
              transform 2s cubic-bezier(0.25, 0.46, 0.45, 0.94);
}

.m-scroll-trigger.animate--fade-in-up.m-scroll-trigger--offscreen {
  opacity: 0;
  transform: translateY(80px);
}

.m-scroll-trigger.animate--fade-in-up:not(.m-scroll-trigger--offscreen) {
  opacity: 1;
  transform: translateY(0);
}

.m-scroll-trigger[data-cascade] {
  transition-delay: calc(var(--animation-order, 0) * 0.15s);
}

